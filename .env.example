# Copie ce fichier en .env.local et remplis les valeurs.
# .env.local n'est jamais commité (voir .gitignore).

# --- Base de données ---------------------------------------------------------
# MongoDB Atlas (gratuit en M0) ou une instance locale.
MONGODB_URI=mongodb://127.0.0.1:27017/chunwah

# --- Sessions admin ----------------------------------------------------------
# 32 caractères minimum. Générer avec :  openssl rand -base64 32
AUTH_SECRET=remplace-moi-par-une-chaine-aleatoire-de-32-caracteres-minimum

# --- Upload d'images ET de vidéos (Cloudinary, gratuit) ----------------------
# Sert aussi bien les images (couvertures, posters) que les vidéos de la section
# « L'académie en mouvement » de l'accueil. Les vidéos sont téléversées
# directement du navigateur vers Cloudinary (upload signé) pour ne pas heurter
# la limite de taille des requêtes serverless.
# Sans ces clés, l'admin accepte quand même une URL collée à la main — y compris
# un chemin auto-hébergé du type /videos/mon-clip.mp4 placé dans /public.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
