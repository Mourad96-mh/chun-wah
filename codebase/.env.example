# Copie ce fichier en .env.local et remplis les valeurs.
# .env.local n'est jamais commité (voir .gitignore).
#
# ARCHITECTURE SPLIT : ce dossier (codebase/) est le FRONTEND (export statique
# Next → Hostinger). La base de données, l'auth et Cloudinary vivent désormais
# dans l'API Express (codebase/server/). Le frontend n'a donc plus besoin de
# MONGODB_URI ni de clés Cloudinary — juste de l'URL de l'API.

# --- API (backend Express sur Render) ----------------------------------------
# URL publique de l'API, utilisée dans le navigateur (admin + rafraîchissement
# en direct du blog). En dev local : http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Même API, utilisée AU BUILD par scripts/sync-content.mjs pour baker le snapshot
# des articles (SEO). En général identique à NEXT_PUBLIC_API_URL.
CONTENT_API_URL=http://localhost:4000

# --- Divers ------------------------------------------------------------------
# URL canonique du site (pour les balises SEO/OpenGraph).
NEXT_PUBLIC_SITE_URL=https://chunwah.ma
