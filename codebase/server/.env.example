# API Chun Wah (Express) — copier en .env et remplir.
# En production ces valeurs se règlent dans le dashboard Render (jamais commit).

# Base de données MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/chunwah

# Secret de signature des JWT (32+ caractères). Générer : openssl rand -base64 32
JWT_SECRET=change-me-32-chars-minimum-please-xxxxx

# Origines autorisées à appeler l'API (le site sur Hostinger + le dev local),
# séparées par des virgules.
CORS_ORIGIN=https://cwtcma-morocco.com,https://www.cwtcma-morocco.com,http://localhost:3000

# Cloudinary (uploads d'images). Laisser vide → l'admin colle des URLs.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
